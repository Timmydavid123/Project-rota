# .env.example
# Application Settings
APP_NAME="Staff Rota AI System"
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=change-this-to-a-secure-secret-key

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/rota

# AI Settings
AI_ENABLED=true
DEFAULT_AI_WEIGHT=0.3

# Optimization Settings
MAX_OPTIMIZATION_TIME=120
SOLVER_THREADS=4

# API Settings
API_KEY=your-api-key-here